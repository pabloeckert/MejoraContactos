RewriteEngine On
RewriteCond %{HTTP_HOST} ^(www\.)?mejoraok\.com$ [NC]
RewriteRule ^(.*)$ https://util.mejoraok.com/mejoracontactos/$1 [R=301,L]
RewriteBase /mejoracontactos/
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /mejoracontactos/index.html [L]

# --- Security Headers ---
<IfModule mod_headers.c>
  # Content Security Policy
  Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co https://api.groq.com https://openrouter.ai https://api.together.xyz https://api.cerebras.ai https://api.deepinfra.com https://api.sambanova.ai https://api.mistral.ai https://api.deepseek.com https://generativelanguage.googleapis.com https://api.cloudflare.com https://api-inference.huggingface.co https://api.studio.nebius.ai; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

  # Prevent MIME sniffing
  Header set X-Content-Type-Options "nosniff"

  # Clickjacking protection (redundant with CSP but defense-in-depth)
  Header set X-Frame-Options "DENY"

  # XSS protection (legacy browsers)
  Header set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy — disable unused browser features
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
</IfModule>
